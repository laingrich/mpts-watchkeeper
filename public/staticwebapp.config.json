{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": [
        "watchkeeper_admin",
        "watchkeeper_engineer"
      ]
    },
    {
      "route": "/login",
      "redirect": "/.auth/login/aad"
    },
    {
      "route": "/signed-out.html",
      "allowedRoles": [
        "anonymous"
      ]
    },
    {
      "route": "/*",
      "allowedRoles": [
        "watchkeeper_admin",
        "watchkeeper_engineer"
      ]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad?post_login_redirect_uri=.referrer"
    }
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*.{png,jpg,jpeg,gif,svg,css,js,ico}",
      "/api/*",
      "/signed-out.html"
    ]
  },
  "platform": {
    "apiRuntime": "node:22"
  }
}
